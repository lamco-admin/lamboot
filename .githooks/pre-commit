#!/usr/bin/env bash
# Integrated Development Framework — pre-commit hook for LamBoot
#
# Customized for UEFI cross-compilation:
# - cargo test is skipped (UEFI binaries can't run on host)
# - cargo clippy uses the default target from .cargo/config.toml
# - cargo check verifies compilation for both targets

set -e

echo "pre-commit: checking format..."
rustup run nightly cargo fmt --check

echo "pre-commit: running clippy..."
cargo clippy

echo "pre-commit: checking x86_64 build..."
cargo check --target x86_64-unknown-uefi

echo "pre-commit: all checks passed"
